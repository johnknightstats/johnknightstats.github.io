spread_diffs <- mapply(function(low, high) {
rookies[[high]] - rookies[[low]]
}, low_vars, high_vars)
if (is.null(dim(spread_diffs))) {
spread_diffs <- matrix(spread_diffs, ncol = 1)
}
rookies$Spread <- rowMeans(spread_diffs, na.rm = TRUE)
# ---- STEP 9: Add combine_participant ----
combine_vars <- c("Dash", "Strength", "Agility", "Jump")
combine_vars_present <- intersect(combine_vars, names(rookies))
rookies <- rookies %>%
mutate(
combine_participant = ifelse(
rowSums(select(., all_of(combine_vars_present)), na.rm = TRUE) == 0,
0,
1
)
)
# ---- STEP 10: Initialize prediction output columns ----
rookies$Predicted_Overall <- NA_real_
rookies$Prediction_Status <- NA_character_
# ---- STEP 11: Score players by position group ----
for (pos in position_groups) {
if (is.null(models[[pos]]) || is.null(model_features[[pos]])) next
rows <- which(rookies$Position_Group == pos)
if (length(rows) == 0) next
feat_vec <- model_features[[pos]]
# Add any missing feature columns as NA so column selection won't fail
missing_feats <- setdiff(feat_vec, names(rookies))
if (length(missing_feats) > 0) {
for (f in missing_feats) {
rookies[[f]] <- NA_real_
}
}
# Build prediction frame in exact saved feature order
X_pred <- rookies[rows, feat_vec, drop = FALSE]
# Force numeric
X_pred[] <- lapply(X_pred, function(col) as.numeric(col))
# Keep track of which original rows remain after removing incomplete cases
keep_idx <- complete.cases(X_pred)
if (!any(keep_idx)) {
rookies$Prediction_Status[rows] <- "Skipped: incomplete predictors"
cat("No complete rows for", pos, "\n")
next
}
X_pred_complete <- X_pred[keep_idx, , drop = FALSE]
rows_complete <- rows[keep_idx]
# Predict
preds <- predict(models[[pos]], as.matrix(X_pred_complete))
# Write predictions back to the correct original rows
rookies$Predicted_Overall[rows_complete] <- preds
rookies$Prediction_Status[rows_complete] <- "Predicted"
# Mark incomplete rows explicitly
if (any(!keep_idx)) {
rookies$Prediction_Status[rows[!keep_idx]] <- "Skipped: incomplete predictors"
}
cat(
"Predicted", length(preds), "players for", pos,
"(", sum(!keep_idx), "skipped for missing data )\n"
)
}
# ---- STEP 12: Optional rounding ----
rookies$Predicted_Overall <- round(rookies$Predicted_Overall, 2)
# ---- STEP 13: View results ----
print(head(rookies[, c("Player_ID", "Position_Group", "Predicted_Overall", "Prediction_Status")]))
# ---- STEP 14: Save predictions ----
write.csv(rookies, "/volumes/NO NAME/FIFArage/predicted_player_ratings.csv", row.names = FALSE)
cat("Done. Predictions saved to predicted_player_ratings.csv\n")
