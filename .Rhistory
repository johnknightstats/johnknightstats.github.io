aes(x=x_pos, y=-0.7, label=round_label),
inherit.aes=FALSE,
size=3.2,
vjust=1
) +
scale_x_continuous(
breaks=year_labels$x_mid,
labels=year_labels$year,
expand=expansion(mult=c(0.01, 0.01))
) +
scale_y_continuous(
limits=c(-0.8, max(plot_df$sg_ott, na.rm=TRUE) + 0.2),
expand=expansion(mult=c(0, 0.02))
) +
labs(
title="Scottie Scheffler at Augusta: Strokes Gained Off the Tee by Round",
x=NULL,
y="SG: Off the Tee"
) +
coord_cartesian(clip="off") +
theme_minimal(base_size=13) +
theme(
plot.title=element_text(face="bold", size=15),
axis.text.x=element_text(size=10, margin=margin(t=10)),
panel.grid.major.x=element_blank(),
panel.grid.minor=element_blank(),
plot.margin=margin(10, 10, 18, 10)
)
library(tidyverse)
library(janitor)
df <- read_csv("scheffler_augusta_ott.csv", trim_ws=TRUE, show_col_types=FALSE) %>%
clean_names()
plot_df <- df %>%
pivot_longer(
cols=c(r1, r2, r3, r4),
names_to="round",
values_to="sg_ott"
) %>%
mutate(
year=as.integer(year),
round=factor(round, levels=c("r1", "r2", "r3", "r4")),
round_label=str_to_upper(as.character(round))
) %>%
arrange(year, round) %>%
group_by(year) %>%
mutate(round_index=row_number()) %>%
ungroup() %>%
mutate(
year_index=as.numeric(factor(year)),
x_pos=year_index * 5 + round_index
)
year_labels <- plot_df %>%
group_by(year) %>%
summarise(x_mid=mean(x_pos), .groups="drop")
ggplot(plot_df, aes(x=x_pos, y=sg_ott)) +
geom_col(width=0.8, fill="#233D4D") +
geom_hline(yintercept=0, linewidth=0.4, color="grey45") +
geom_text(
aes(x=x_pos, y=-0.67, label=round_label),
inherit.aes=FALSE,
size=3.2,
vjust=1
) +
scale_x_continuous(
breaks=year_labels$x_mid,
labels=year_labels$year,
expand=expansion(mult=c(0.01, 0.01))
) +
scale_y_continuous(
limits=c(-0.8, max(plot_df$sg_ott, na.rm=TRUE) + 0.2),
expand=expansion(mult=c(0, 0.02))
) +
labs(
title="Scottie Scheffler at Augusta: Strokes Gained Off the Tee by Round",
x=NULL,
y="SG: Off the Tee"
) +
coord_cartesian(clip="off") +
theme_minimal(base_size=13) +
theme(
plot.title=element_text(face="bold", size=15),
axis.text.x=element_text(size=10, margin=margin(t=10)),
panel.grid.major.x=element_blank(),
panel.grid.minor=element_blank(),
plot.margin=margin(10, 10, 18, 10)
)
