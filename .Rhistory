setwd("~/Games/FOF/Draft Model 2025")
# ---- STEP 1: Load required libraries ----
library(xgboost)
library(dplyr)
library(data.table)
library(readr)
library(jsonlite)
# ---- STEP 2: Define position groups ----
position_groups <- c(
"QB", "RB", "FB", "WR", "TE", "T", "G", "C",
"DT", "DE", "ILB", "OLB", "CB", "S", "K", "P", "LS"
)
# ---- STEP 3: Load saved XGBoost JSON models and feature lists ----
# Assumes training script created:
#   deploy_models/xgb_model_<POS>.json
#   deploy_models/features/xgb_model_<POS>_features.csv
#   deploy_models/metadata/xgb_model_<POS>_metadata.json
models <- list()
model_features <- list()
model_metadata <- list()
for (pos in position_groups) {
model_path <- file.path("deploy_models", paste0("xgb_model_", pos, ".json"))
feature_path <- file.path("deploy_models", "features", paste0("xgb_model_", pos, "_features.csv"))
metadata_path <- file.path("deploy_models", "metadata", paste0("xgb_model_", pos, "_metadata.json"))
if (file.exists(model_path) && file.exists(feature_path)) {
models[[pos]] <- xgb.load(model_path)
model_features[[pos]] <- read_csv(feature_path, show_col_types = FALSE)$feature
if (file.exists(metadata_path)) {
model_metadata[[pos]] <- fromJSON(metadata_path)
} else {
model_metadata[[pos]] <- NULL
}
cat("Loaded model and features for", pos, "\n")
} else {
cat("Model and/or feature file missing for", pos, "- skipping this position\n")
}
}
# ---- STEP 4: Load rookie data ----
rookies <- read.csv(
"~/NO NAME/FIFArage/rookies.csv"
)
