# ================================================
# XGBOOST PREDICTIONS WITH POSITIONAL MODELS
# JSON deployment version
# ================================================
setwd("~/Games/FOF/Draft Model 2025")
# ---- STEP 1: Load required libraries ----
library(xgboost)
library(dplyr)
library(data.table)
library(readr)
library(jsonlite)
# ---- STEP 2: Define position groups ----
position_groups <- c(
"QB", "RB", "FB", "WR", "TE", "T", "G", "C",
"DT", "DE", "ILB", "OLB", "CB", "S", "K", "P", "LS"
)
# ---- STEP 3: Load saved XGBoost JSON models and feature lists ----
# Assumes training script created:
#   deploy_models/xgb_model_<POS>.json
#   deploy_models/features/xgb_model_<POS>_features.csv
#   deploy_models/metadata/xgb_model_<POS>_metadata.json
models <- list()
model_features <- list()
model_metadata <- list()
for (pos in position_groups) {
model_path <- file.path("deploy_models", paste0("xgb_model_", pos, ".json"))
feature_path <- file.path("deploy_models", "features", paste0("xgb_model_", pos, "_features.csv"))
metadata_path <- file.path("deploy_models", "metadata", paste0("xgb_model_", pos, "_metadata.json"))
if (file.exists(model_path) && file.exists(feature_path)) {
models[[pos]] <- xgb.load(model_path)
model_features[[pos]] <- read_csv(feature_path, show_col_types = FALSE)$feature
if (file.exists(metadata_path)) {
model_metadata[[pos]] <- fromJSON(metadata_path)
} else {
model_metadata[[pos]] <- NULL
}
cat("Loaded model and features for", pos, "\n")
} else {
cat("Model and/or feature file missing for", pos, "- skipping this position\n")
}
}
# ---- STEP 4: Load rookie data ----
rookies <- read.csv(
"/Volumes/NO NAME/FIFArage/rookies.csv"
)
draft_personal <- read.csv(
"/Volumes/NO NAME/FIFArage/draft_personal.csv"
)
player_info <- read.csv(
"/Volumes/NO NAME/FIFArage/player_information.csv"
)
rookies <- merge(rookies, draft_personal, by = "Player_ID")
# ---- STEP 5: Determine draft year ----
latest_active_year <- player_info %>%
group_by(Draft_Year) %>%
summarize(Total_Seasons = sum(Number_of_Seasons, na.rm = TRUE), .groups = "drop") %>%
filter(Total_Seasons > 0) %>%
summarize(Latest_Year = max(Draft_Year)) %>%
pull(Latest_Year)
draft_year <- latest_active_year + 1
# ---- STEP 6: Calculate Age ----
player_info <- player_info[, c("Player_ID", "Year_Born", "Month_Born", "Day_Born")]
rookies <- merge(rookies, player_info, all.x = TRUE, all.y = FALSE, by = "Player_ID")
rookies <- rookies %>%
mutate(
Age = round(
as.numeric(
as.Date(paste0(draft_year, "-09-01")) -
as.Date(paste(Year_Born, Month_Born, Day_Born, sep = "-"))
) / 365.25,
2
)
)
# ---- STEP 7: Create Mid_ columns ----
low_vars <- grep("^Low_", names(rookies), value = TRUE)
high_vars <- gsub("^Low_", "High_", low_vars)
mid_vars <- gsub("^Low_", "Mid_", low_vars)
# Keep only valid Low_/High_ pairs
valid_pair_idx <- high_vars %in% names(rookies)
low_vars <- low_vars[valid_pair_idx]
high_vars <- high_vars[valid_pair_idx]
mid_vars <- mid_vars[valid_pair_idx]
for (i in seq_along(low_vars)) {
rookies[[mid_vars[i]]] <- rowMeans(
rookies[, c(low_vars[i], high_vars[i])],
na.rm = TRUE
)
}
# ---- STEP 8: Create Spread ----
# Match the training logic:
# Spread = row mean of (High - Low), using all valid pairs, na.rm = TRUE
spread_diffs <- mapply(function(low, high) {
rookies[[high]] - rookies[[low]]
}, low_vars, high_vars)
if (is.null(dim(spread_diffs))) {
spread_diffs <- matrix(spread_diffs, ncol = 1)
}
rookies$Spread <- rowMeans(spread_diffs, na.rm = TRUE)
# ---- STEP 9: Add combine_participant ----
combine_vars <- c("Dash", "Strength", "Agility", "Jump")
combine_vars_present <- intersect(combine_vars, names(rookies))
rookies <- rookies %>%
mutate(
combine_participant = ifelse(
rowSums(select(., all_of(combine_vars_present)), na.rm = TRUE) == 0,
0,
1
)
)
# ---- STEP 10: Initialize prediction output columns ----
rookies$Predicted_Overall <- NA_real_
rookies$Prediction_Status <- NA_character_
# ---- STEP 11: Score players by position group ----
for (pos in position_groups) {
if (is.null(models[[pos]]) || is.null(model_features[[pos]])) next
rows <- which(rookies$Position_Group == pos)
if (length(rows) == 0) next
feat_vec <- model_features[[pos]]
# Add any missing feature columns as NA so column selection won't fail
missing_feats <- setdiff(feat_vec, names(rookies))
if (length(missing_feats) > 0) {
for (f in missing_feats) {
rookies[[f]] <- NA_real_
}
}
# Build prediction frame in exact saved feature order
X_pred <- rookies[rows, feat_vec, drop = FALSE]
# Force numeric
X_pred[] <- lapply(X_pred, function(col) as.numeric(col))
# Keep track of which original rows remain after removing incomplete cases
keep_idx <- complete.cases(X_pred)
if (!any(keep_idx)) {
rookies$Prediction_Status[rows] <- "Skipped: incomplete predictors"
cat("No complete rows for", pos, "\n")
next
}
X_pred_complete <- X_pred[keep_idx, , drop = FALSE]
rows_complete <- rows[keep_idx]
# Predict
preds <- predict(models[[pos]], as.matrix(X_pred_complete))
# Write predictions back to the correct original rows
rookies$Predicted_Overall[rows_complete] <- preds
rookies$Prediction_Status[rows_complete] <- "Predicted"
# Mark incomplete rows explicitly
if (any(!keep_idx)) {
rookies$Prediction_Status[rows[!keep_idx]] <- "Skipped: incomplete predictors"
}
cat(
"Predicted", length(preds), "players for", pos,
"(", sum(!keep_idx), "skipped for missing data )\n"
)
}
# ---- STEP 12: Optional rounding ----
rookies$Predicted_Overall <- round(rookies$Predicted_Overall, 2)
# ---- STEP 13: View results ----
print(head(rookies[, c("Player_ID", "Position_Group", "Predicted_Overall", "Prediction_Status")]))
# ---- STEP 14: Save predictions ----
write.csv(rookies, "predicted_player_ratings.csv", row.names = FALSE)
cat("Done. Predictions saved to predicted_player_ratings.csv\n")
