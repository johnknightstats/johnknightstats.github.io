tuneGrid = xgb_grid,
verbose = FALSE
)
best_rmse <- min(model$results$RMSE)
mean_pred <- mean(predict(model, as.matrix(X)))
mean_y <- mean(y)
cv_results <- rbind(cv_results, data.frame(
Position_Group = pos,
Feature_Set = set_name,
RMSE = best_rmse,
Mean_Pred = mean_pred,
Mean_Actual = mean_y
))
} else {
cat("  Skipping", pos, "– not enough data (n =", nrow(X), ")\n")
}
}
}
library(xgboost)
library(dplyr)
library(jsonlite)
setwd("~/Games/FOF/Draft Model 2025")
model_data <- read.csv("model_data.csv")
base_vars <- c("Height","Weight","Dash","Solecismic","Strength","Agility","Jump",
"Position_Specific","Developed","Grade","combine_participant","Age")
target <- "Future_Overall_Year_1"
# Create Mid_ and Spread
low_vars <- grep("^Low_", names(model_data), value=TRUE)
high_vars <- gsub("^Low_", "High_", low_vars)
mid_vars <- gsub("^Low_", "Mid_", low_vars)
for(i in seq_along(low_vars)) {
model_data[[mid_vars[i]]] <- rowMeans(model_data[, c(low_vars[i], high_vars[i])], na.rm=TRUE)
}
spread_diffs <- mapply(function(low, high) {
model_data[[high]] - model_data[[low]]
}, low_vars, high_vars)
if(is.null(dim(spread_diffs))) spread_diffs <- matrix(spread_diffs, ncol=1)
model_data$Spread <- rowMeans(spread_diffs, na.rm=TRUE)
# Create combine flag
combine_vars <- c("Dash","Strength","Agility","Jump")
model_data <- model_data %>%
mutate(combine_participant=ifelse(rowSums(select(., all_of(combine_vars)), na.rm=TRUE)==0, 0, 1))
features <- c(base_vars, grep("^Mid_", names(model_data), value=TRUE), "Spread")
final_params <- list(
booster="gbtree",
objective="reg:squarederror",
max_depth=3,
eta=0.05,
gamma=0,
colsample_bytree=0.8,
min_child_weight=1,
subsample=0.8,
verbosity=0
)
nrounds_final <- 200
dir.create("deploy_models", showWarnings=FALSE)
position_list <- unique(model_data$Position_Group)
for(pos in position_list) {
cat("Training:", pos, "\n")
df_pos <- model_data %>% filter(Position_Group==pos)
X <- df_pos[, intersect(features, names(df_pos)), drop=FALSE]
y <- df_pos[[target]]
# Remove incomplete cases
keep <- complete.cases(X, y)
X <- X[keep, , drop=FALSE]
y <- y[keep]
if(nrow(X) < 30) {
cat("Skipping", pos, "- not enough data\n")
next
}
# Remove zero-variance columns and SAVE the final feature list
nzv <- caret::nearZeroVar(X)
if(length(nzv) > 0) X <- X[, -nzv, drop=FALSE]
feature_names <- colnames(X)
dtrain <- xgb.DMatrix(data=as.matrix(X), label=y, feature_names=feature_names)
set.seed(889)
model <- xgb.train(
params=final_params,
data=dtrain,
nrounds=nrounds_final,
verbose=0
)
model_file <- file.path("deploy_models", paste0("xgb_model_", pos, ".json"))
feat_file  <- file.path("deploy_models", paste0("xgb_model_", pos, "_features.csv"))
meta_file  <- file.path("deploy_models", paste0("xgb_model_", pos, "_metadata.json"))
xgb.save(model, model_file)
write.csv(data.frame(feature=feature_names), feat_file, row.names=FALSE)
metadata <- list(
position_group=pos,
target=target,
xgboost_version=as.character(packageVersion("xgboost")),
nrounds=nrounds_final,
params=final_params,
training_rows=nrow(X),
feature_count=length(feature_names)
)
write_json(metadata, meta_file, pretty=TRUE, auto_unbox=TRUE)
}
cat("Done.\n")
